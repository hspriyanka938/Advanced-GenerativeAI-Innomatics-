class SmartLight:
    def __init__(self, light_name):
        self.light_name = light_name
        self.status = "OFF"

    def set_action(self, action):
        # Normalizing input to uppercase for consistency
        self.status = action.upper()

    def display_status(self):
        print(f"{self.light_name} is {self.status}")

# Execution
light = SmartLight("Bedroom Light")
light.set_action("ON")
light.display_status()
Bedroom Light is ON
class Employee:
    def __init__(self, name, emp_id, department):
        self.name = name
        self.emp_id = emp_id
        self.department = department

    def display_id_card(self):
        print("Employee ID Card")
        print(f"Name: {self.name}")
        print(f"ID: {self.emp_id}")
        print(f"Department: {self.department}")

# Execution
emp = Employee("Rahul", "EMP102", "IT")
emp.display_id_card()
Employee ID Card
Name: Rahul
ID: EMP102
Department: IT
class Contact:
    def __init__(self, name, phone):
        self.name = name
        self.phone = phone

    def display_contact(self):
        print("Contact Saved")
        print(f"Name: {self.name}")
        print(f"Phone: {self.phone}")

# Execution
contact = Contact("Anita", "9876543210")
contact.display_contact()
Contact Saved
Name: Anita
Phone: 9876543210
class Product:
    def __init__(self, name, price):
        self.name = name
        self.price = price

    def print_tag(self):
        print(f"Product: {self.name}")
        print(f"Price: ₹{self.price}")

# Execution
prod = Product("Headphones", 2499)
prod.print_tag()
Product: Headphones
Price: ₹2499
class Movie:
    def __init__(self, name, rating):
        self.name = name
        self.rating = rating

    def display_details(self):
        print(f"Movie: {self.name}")
        print(f"Rating: {self.rating} / 5")

# Execution
movie = Movie("Inception", 4.8)
movie.display_details()
Movie: Inception
Rating: 4.8 / 5
class DeliveryManager:
    def __init__(self, customer_name, address):
        self.customer_name = customer_name
        self.address = address

    def display_delivery_details(self):
        print("Delivery Details")
        print(f"Customer: {self.customer_name}")
        print(f"Address: {self.address}")

# Execution
delivery = DeliveryManager("Suman", "Hyderabad")
delivery.display_delivery_details()
Delivery Details
Customer: Suman
Address: Hyderabad
