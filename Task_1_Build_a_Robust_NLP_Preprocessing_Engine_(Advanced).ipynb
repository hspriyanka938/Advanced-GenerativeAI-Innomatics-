# Import required libraries
import nltk
import re
import string

from nltk.corpus import stopwords
from nltk.tokenize import word_tokenize
from nltk.stem import PorterStemmer
from nltk.stem import WordNetLemmatizer

# Download required NLTK data
nltk.download('punkt')
nltk.download('stopwords')
nltk.download('wordnet')

# ============================================
# Sample Input Text
# ============================================
text = "Hello! This is Priyanka's NLP Task. Cleaning text data is very important in 2026."

print("Original Text:")
print(text)

# ============================================
# Step 1: Convert to Lowercase
# ============================================
lower_text = text.lower()
print("\nLowercase Text:")
print(lower_text)

# ============================================
# Step 2: Remove Punctuation
# ============================================
no_punct = lower_text.translate(str.maketrans('', '', string.punctuation))
print("\nText after removing punctuation:")
print(no_punct)

# ============================================
# Step 3: Tokenization
# ============================================
tokens = word_tokenize(no_punct)
print("\nTokens:")
print(tokens)

# ============================================
# Step 4: Remove Stopwords
# ============================================
stop_words = set(stopwords.words('english'))
filtered_words = [word for word in tokens if word not in stop_words]

print("\nAfter removing stopwords:")
print(filtered_words)

# ============================================
# Step 5: Remove Numbers
# ============================================
cleaned_words = [re.sub(r'\d+', '', word) for word in filtered_words]

print("\nAfter removing numbers:")
print(cleaned_words)

# ============================================
# Step 6: Stemming
# ============================================
stemmer = PorterStemmer()
stemmed_words = [stemmer.stem(word) for word in cleaned_words]

print("\nStemmed Words:")
print(stemmed_words)

# ============================================
# Step 7: Lemmatization
# ============================================
lemmatizer = WordNetLemmatizer()
lemmatized_words = [lemmatizer.lemmatize(word) for word in cleaned_words]

print("\nLemmatized Words:")
print(lemmatized_words)

# ============================================
# Final Output
# ============================================
print("\nFinal Preprocessed Output:")
print(lemmatized_words)
